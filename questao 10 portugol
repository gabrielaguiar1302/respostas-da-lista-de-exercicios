algoritmo "Login de Usuario"
var
   codigo : inteiro
   senha  : inteiro
inicio
   escreva("Digite o codigo de usuario: ")
   leia(codigo)

   se codigo = 1234 entao
      escreva("Digite a senha: ")
      leia(senha)

      se senha = 9999 entao
         escreval("Acesso permitido!")
      senao
         escreval("Senha incorreta!")
      fimse
   senao
      escreval("Usuario invalido!")
   fimse

fimalgoritmo
